# Copy this file to .env.local and fill in the values from the Firebase console.
# Project settings → General → Your apps → Web app (register one if none exists).
# All NEXT_PUBLIC_* vars are exposed to the browser — do not put secrets here.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=pari-456d0.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=pari-456d0
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=pari-456d0.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=9642187855
NEXT_PUBLIC_FIREBASE_APP_ID=

# The Firebase Auth uid that unlocks the admin panel. Must match firestore.rules
# isSuperAdmin() in the mobile repo — keep them in sync when rotating.
NEXT_PUBLIC_SUPER_ADMIN_UID=HSQ12sTZ1sSMim87gltn7dVvrBI3
